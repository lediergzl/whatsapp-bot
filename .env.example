# WhatsApp Bot Configuration
SESSION_DIR=.wwebjs_auth
AUTHORIZED_GROUPS=group-id-1,group-id-2
ADMIN_NUMBERS=whatsapp-number-1,whatsapp-number-2
# Configuración del bot
APP_URL=https://mi-bot.glitch.me

# Configuración de grupos autorizados (separados por comas)
GRUPOS_AUTORIZADOS=123456789-123456@g.us,987654321-123456@g.us

# Credenciales API (si se conecta a una API externa)
API_URL=https://api.ejemplo.com
API_KEY=tu_api_key
